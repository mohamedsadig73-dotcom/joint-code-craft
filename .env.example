# ==================================
# Lovable Cloud Environment Variables
# ==================================
# هذه المتغيرات يتم إدارتها تلقائياً بواسطة Lovable Cloud
# لا تحتاج إلى تعيينها يدوياً في بيئة التطوير
# للنشر الذاتي، احصل على القيم من لوحة تحكم Lovable Cloud

# ==================================
# Supabase Configuration
# ==================================

# رابط مشروع Supabase الخاص بك
# مثال: https://xxxxxx.supabase.co
VITE_SUPABASE_URL=your_supabase_project_url

# المفتاح العام (Anon Key) - آمن للاستخدام في Frontend
# يمكن مشاركته في الكود المصدري
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# معرف مشروع Supabase
VITE_SUPABASE_PROJECT_ID=your_project_id

# ==================================
# Optional: Edge Functions Secrets
# ==================================
# هذه المتغيرات تُستخدم في Edge Functions فقط
# لا تضعها في frontend - استخدم Lovable Cloud Secrets بدلاً من ذلك

# SUPABASE_URL=your_supabase_url_for_functions
# SUPABASE_ANON_KEY=your_anon_key_for_functions
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key (خطر! لا تشارك)

# ==================================
# Optional: Third-party APIs
# ==================================
# إذا كنت تستخدم خدمات خارجية، أضف مفاتيحها هنا
# تأكد من إضافتها إلى Lovable Cloud Secrets للأمان

# RESEND_API_KEY=your_resend_api_key_for_emails
# SENTRY_DSN=your_sentry_dsn_for_error_tracking
# LOGFLARE_API_KEY=your_logflare_api_key_for_logging

# ==================================
# Development Settings
# ==================================

# بيئة التشغيل
NODE_ENV=development

# المنفذ (Port) - اختياري، الافتراضي 8080
# VITE_PORT=8080

# ==================================
# Notes / ملاحظات
# ==================================
# 
# 1. لا تشارك ملف .env الحقيقي في Git أبداً
# 2. استخدم .env.example للتوثيق فقط
# 3. في Lovable Cloud، المتغيرات البيئية مدارة تلقائياً
# 4. للنشر الذاتي:
#    - انسخ هذا الملف إلى .env
#    - املأ القيم الحقيقية من Lovable Cloud
#    - تأكد من عدم رفع .env إلى Git
# 5. المفاتيح الحساسة (Service Role Key) يجب أن تكون في Secrets فقط
# 6. راجع التوثيق: https://docs.lovable.dev/features/cloud
