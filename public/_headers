# Prevent caching of HTML and service worker files
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/sw-cleanup.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate

# Allow caching for hashed assets (they have unique names per build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
